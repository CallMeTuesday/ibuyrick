# Generate VAPID keys by running: npm run keys
# Copy the output into the vars below and into Railway's environment settings

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=you@example.com

# Required: injected automatically by Railway when you add a Postgres database
DATABASE_URL=postgresql://...

# Optional
POLL_INTERVAL_MINUTES=10

# Set to "false" to pause notifications without stopping the service
# Easier: use Railway's "Suspend Service" button in the dashboard
ENABLED=true
