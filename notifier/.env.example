# Required: your ntfy.sh topic name (pick anything unique, e.g. ibuyrick-abc123)
# Subscribe in the ntfy app with this same topic name
NTFY_TOPIC=your-topic-name-here

# Required: injected automatically by Railway when you add a Postgres database
DATABASE_URL=postgresql://...

# Optional: how often to check for new items (default: 10)
POLL_INTERVAL_MINUTES=10

# Optional: set to "false" to pause notifications without stopping the service
# Easier option: use Railway's "Pause Service" button in the dashboard
ENABLED=true
